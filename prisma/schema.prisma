generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. The Users table (Admins and regular users)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // We will encrypt this later!
  role      Role     @default(USER)
  clients   Client[] // Links users to specific clients
  tickets   Ticket[] // Tickets created by this user
  createdAt DateTime @default(now())
}

// 2. The Clients table
model Client {
  id        String   @id @default(uuid())
  name      String
  users     User[]   // Links clients back to users
  tickets   Ticket[] // All tickets under this client
  createdAt DateTime @default(now())
}

// 3. The Categories table (Task, Request, Incident, etc.)
model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  tickets   Ticket[] 
}

// 4. The Tickets table (The core issue tracker)
model Ticket {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("ACTIVE")
  deadline     DateTime?
  reportedDate DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  
  // This restores the missing connection back to the User model!
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
}

// Pre-defined options for roles and ticket statuses
enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  PENDING
  COMPLETED
  DELAYED
  PAUSED
  POSTPONED
  CANCELLED
}